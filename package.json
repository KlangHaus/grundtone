{
  "name": "grundtone",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "build:packages": "turbo run build --filter=./packages/*",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "clean": "turbo run clean",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,vue,scss,css,json,md,yml,yaml}\"",
    "lint:js": "eslint \"{packages,apps,docs}/**/*.{js,jsx,ts,tsx,vue}\" --fix",
    "lint:js:check": "eslint \"{packages,apps,docs}/**/*.{js,jsx,ts,tsx,vue}\"",
    "lint:styles": "stylelint \"{packages,apps}/**/*.{scss,css,vue}\" --fix",
    "lint:styles:check": "stylelint \"{packages,apps}/**/*.{scss,css,vue}\"",
    "lint:format": "prettier --check \"**/*.{ts,tsx,vue,scss,css,json,md,yml,yaml}\"",
    "commitlint": "commitlint --edit",
    "prepare": "husky",
    "docs:dev": "pnpm --filter @grundtone/docs dev",
    "docs:build": "turbo build --filter=@grundtone/docs",
    "docs:preview": "pnpm --filter @grundtone/docs preview",
    "changeset": "changeset",
    "changeset:add": "changeset add",
    "changeset:status": "changeset status --verbose",
    "changeset:empty": "changeset add --empty",
    "version-packages": "changeset version && npx tsx scripts/add-changelog-dates.ts && pnpm install --lockfile-only",
    "release": "pnpm build:packages && changeset publish",
    "release:snapshot": "pnpm build:packages && changeset version --snapshot && changeset publish --tag snapshot --no-git-tag",
    "release:snapshot:tagged": "pnpm build:packages && changeset version --snapshot",
    "prerelease:enter": "changeset pre enter",
    "prerelease:exit": "changeset pre exit",
    "prerelease:next": "changeset pre enter next",
    "prerelease:beta": "changeset pre enter beta",
    "prerelease:alpha": "changeset pre enter alpha"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.33.0",
    "@neoconfetti/react": "^1.0.0",
    "@types/node": "22.15.17",
    "@typescript-eslint/eslint-plugin": "8.39.0",
    "@typescript-eslint/parser": "8.39.0",
    "@vitest/browser": "3.1.3",
    "@vitest/coverage-v8": "3.1.3",
    "eslint": "9.33.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-vue": "^10.8.0",
    "filesize": "^11.0.2",
    "husky": "^9.1.7",
    "jsdom": "26.1.0",
    "lint-staged": "^15.5.2",
    "playwright": "^1.54.2",
    "postcss-html": "^1.8.0",
    "postcss-scss": "^4.0.9",
    "prettier": "3.5.3",
    "rimraf": "6.0.1",
    "sharp": "^0.34.5",
    "strip-ansi": "^7.1.0",
    "stylelint": "^16.23.1",
    "stylelint-config-prettier-scss": "^1.0.0",
    "stylelint-config-standard-scss": "^15.0.1",
    "stylelint-scss": "^6.12.1",
    "turbo": "2.5.3 ",
    "typescript": "5.8.3",
    "vite": "^6.4.1",
    "vitepress": "^1.6.4",
    "vitest": "3.1.3",
    "vue": "^3.5.26",
    "vue-eslint-parser": "^10.2.0",
    "vue-tsc": "2.2.10"
  },
  "packageManager": "pnpm@10.14.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "volta": {
    "node": "24.13.0",
    "pnpm": "10.14.0"
  },
  "lint-staged": {
    "*.{ts,tsx,vue,scss,css,json,md,yml,yaml}": [
      "prettier --write"
    ],
    "*.{js,jsx,ts,tsx,vue}": [
      "eslint --fix"
    ],
    "*.{scss,css,vue}": [
      "stylelint --fix"
    ]
  },
  "pnpm": {
    "auditConfig": {
      "ignoreCves": [
        "CVE-2026-33128",
        "CVE-2026-33131",
        "CVE-2026-33490"
      ],
      "ignoreGhsas": [
        "GHSA-4hxc-9384-m385",
        "GHSA-q5pr-72pq-83v3",
        "GHSA-wr4h-v87w-p3r7",
        "GHSA-xffm-g5w8-qvg7"
      ]
    },
    "overrides": {
      "file-type": ">=16.5.4",
      "node-fetch": ">=2.6.7",
      "glob": ">=11.1.0",
      "@octokit/request-error": ">=5.1.1",
      "@octokit/request": ">=8.4.1",
      "@octokit/plugin-paginate-rest": ">=9.2.2",
      "brace-expansion": ">=5.0.5",
      "esbuild": ">=0.25.0",
      "flatted": ">=3.4.2",
      "minimatch": ">=9.0.7",
      "node-forge": ">=1.4.0",
      "picomatch": ">=4.0.4",
      "serialize-javascript": ">=7.0.5",
      "srvx": ">=0.11.13",
      "yaml": ">=2.8.3"
    }
  },
  "repository": "grundtone/grundtone",
  "author": "Allan Asp <mail@allanasp.dk>"
}
