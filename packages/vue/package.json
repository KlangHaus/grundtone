{
  "name": "@grundtone/vue",
  "version": "2.15.0",
  "description": "Vue 3 UI components for Grundtone",
  "license": "MIT",
  "private": false,
  "type": "module",
  "main": "./dist/index.umd.cjs",
  "module": "./dist/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.umd.cjs"
    },
    "./css": "./dist/index.css",
    "./dist/style.css": "./dist/index.css",
    "./scss": {
      "sass": "./scss/index.scss",
      "default": "./scss/index.scss"
    },
    "./scss/lib": {
      "sass": "./scss/lib.scss",
      "default": "./scss/lib.scss"
    },
    "./scss/breakpoints": {
      "sass": "./scss/breakpoints.scss",
      "default": "./scss/breakpoints.scss"
    },
    "./scss/colors": {
      "sass": "./scss/colors.scss",
      "default": "./scss/colors.scss"
    },
    "./scss/color-palette": {
      "sass": "./scss/color-palette.scss",
      "default": "./scss/color-palette.scss"
    }
  },
  "files": [
    "dist",
    "scss"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/grundtone/grundtone.git",
    "directory": "packages/vue"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "clean": "rm -rf .turbo node_modules dist",
    "test": "vitest",
    "prepublishOnly": "test -d dist || pnpm run build"
  },
  "peerDependencies": {
    "vue": "^3.5.13"
  },
  "dependencies": {
    "@grundtone/core": "workspace:*",
    "@grundtone/design-system": "workspace:*",
    "@grundtone/icons": "workspace:*",
    "@grundtone/utils": "workspace:*"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@testing-library/jest-dom": "^6.8.0",
    "@vitejs/plugin-vue": "^5.0.3",
    "@vue/test-utils": "^2.4.0",
    "axe-core": "^4.10.3",
    "sass": "^1.87.0",
    "vitest-axe": "^0.1.0"
  }
}
