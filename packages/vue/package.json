{
  "name": "@grundtone/vue",
  "version": "2.23.3",
  "description": "Vue 3 UI components for Grundtone",
  "license": "MIT",
  "private": false,
  "type": "module",
  "main": "./dist/index.umd.js",
  "module": "./dist/index.js",
  "types": "./dist/types/index.d.ts",
  "sideEffects": [
    "**/*.css",
    "**/*.scss"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.umd.js"
    },
    "./css": "./dist/index.css",
    "./css/utilities": "./dist/utilities.css",
    "./scss": {
      "sass": "./scss/index.scss",
      "default": "./scss/index.scss"
    },
    "./scss/lib": {
      "sass": "./scss/lib.scss",
      "default": "./scss/lib.scss"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "scss",
    "src"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/grundtone/grundtone.git",
    "directory": "packages/vue"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "lint": "eslint src",
    "build": "vite build && node scripts/inject-css-imports.mjs && vite build --config vite.umd.config.ts && node scripts/copy-bundles.mjs",
    "dev": "vite build --watch",
    "clean": "rm -rf .turbo node_modules dist",
    "test": "vitest",
    "prepublishOnly": "test -d dist || pnpm run build"
  },
  "peerDependencies": {
    "vue": "^3.5.13"
  },
  "dependencies": {
    "@grundtone/core": "workspace:*",
    "@grundtone/design-system": "workspace:*",
    "@grundtone/icons": "workspace:*",
    "@grundtone/utils": "workspace:*"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@testing-library/jest-dom": "^6.8.0",
    "@vitejs/plugin-vue": "^5.0.3",
    "@vue/test-utils": "^2.4.0",
    "axe-core": "^4.10.3",
    "sass": "^1.87.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest-axe": "^0.1.0"
  }
}
