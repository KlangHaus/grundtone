{
  "name": "@grundtone/composables",
  "version": "2.0.0",
  "description": "Vue 3 composables for Grundtone",
  "license": "MIT",
  "private": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/grundtone/grundtone.git",
    "directory": "packages/composables"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf .turbo node_modules dist",
    "test": "vitest --passWithNoTests",
    "prepublishOnly": "test -d dist || pnpm run build"
  },
  "peerDependencies": {
    "vue": "^3.5.13"
  },
  "dependencies": {
    "@grundtone/core": "workspace:*",
    "@grundtone/design-tokens": "workspace:*",
    "@grundtone/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.17.45",
    "tsup": "^8.0.2"
  }
}
