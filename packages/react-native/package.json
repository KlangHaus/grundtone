{
  "name": "@grundtone/react-native",
  "version": "2.9.1",
  "description": "React Native theme provider and hooks for Grundtone design system",
  "license": "MIT",
  "private": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/grundtone/grundtone.git",
    "directory": "packages/react-native"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf .turbo node_modules dist",
    "prepublishOnly": "test -d dist || pnpm run build"
  },
  "peerDependencies": {
    "react": ">=18.0.0 || >=19.0.0",
    "react-native": ">=0.72.0",
    "expo": ">=52.0.0",
    "react-native-svg": ">=13.0.0"
  },
  "peerDependenciesMeta": {
    "react-native-svg": {
      "optional": true
    },
    "expo": {
      "optional": true
    }
  },
  "dependencies": {
    "@grundtone/core": "workspace:*",
    "@grundtone/icons": "workspace:*",
    "@grundtone/utils": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "tsup": "^8.0.2",
    "typescript": "^5.0.0"
  }
}
